# Copy to .env and adjust. All values here are the safe defaults compose already applies;
# the file exists to document what is configurable and to override infra in production.
# Dev is cloud-free — photo storage is the local MinIO stand-in (production uses Cloudflare R2).

# ── Infrastructure (production points these at managed Mongo/Redis) ──
MONGO_CONNECTION_STRING=mongodb://mongodb:27017/?replicaSet=rs0
MONGO_DATABASE=fogos
REDIS_CONNECTION_STRING=redis:6379

# ── Object storage (local MinIO in dev; production sets these to Cloudflare R2, see deploy/.env.example) ──
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=incident-photos
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/incident-photos

# ── Ops (Discord webhooks). Empty = silent no-op. ──
DISCORD_GENERAL_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=
DISCORD_DRYRUN_WEBHOOK=

# ── Auth (self-issued RS256 JWTs). Defaults live in the API's appsettings.json under ──
# ── the "Auth" section; override via standard Section__Key env vars on the API        ──
# ── container. Leave the PEM empty in dev to auto-generate an ephemeral key (a loud    ──
# ── warning is logged; tokens die on restart). In prod set a PEM string or file path.  ──
# Auth__Issuer=fogos.pt
# Auth__Audience=fogos-api
# Auth__AccessTokenMinutes=15
# Auth__RefreshTokenDays=30
# Auth__RsaPrivateKeyPem=

# ── Rate limits (per-tier, tunable). Requests/min, GraphQL cost budget/min, max subs. ──
# ── Defaults live in appsettings.json ("RateLimit" section); override per tier, e.g.:  ──
# RateLimit__Anonymous__Requests=30
# RateLimit__Anonymous__CostBudget=500

# ── Photo-upload gates (tunable; "PhotoGate" section). ──
# PhotoGate__PerIpPerMinute=3

# ── External sources (keys empty = source disabled; FR24 budget 0 = guard disabled). ──
NASA_FIRMS_KEY=
FR24_API_KEY=
FR24_MONTHLY_BUDGET=0
FR24_MODE=DryRun   # FR24 spend gate: Off | DryRun (poll gates run, no paid call) | On (live, needs key+budget)

# ── Errors ──
SENTRY_DSN=
