# ─────────────────────────────────────────────────────────────────────────────
# FogosPortugal — deploy/.env  (copy to ~/fogos-deploy/.env and fill in)
#
# Everything the compose stack reads. Unset keys fall back to the defaults baked
# into deploy/compose.yml (each line shows that default). Organised in three blocks:
#   1. REQUIRED — stack won't be secure / won't serve correctly until you set these
#   2. OPTIONAL — external data sources (the feature stays off while the key is empty)
#   3. OPTIONAL — push notifications (FCM; disabled-safe, boots with no credentials)
# …plus a short OPTIONAL ops/errors footer.
#
# NEVER commit the real .env — it is the primary disaster-recovery artifact
# (back it up offsite; see deploy/README.md §6).
# ─────────────────────────────────────────────────────────────────────────────

# ═══ 1. REQUIRED ═════════════════════════════════════════════════════════════
# The stack BOOTS on the defaults below (single-host, internal Docker network),
# but before exposing it you MUST set a real MINIO_ROOT_PASSWORD, and for a proper
# deploy also STORAGE_PUBLIC_BASE_URL (external photo URLs) and
# AUTH_RSA_PRIVATE_KEY_PEM (stable tokens across restarts).

# Host port bindings — published on 127.0.0.1 only; the host Cloudflare tunnel maps
# hostnames onto them. WEB_PORT → apex domain, API_PORT → api.<domain>.
WEB_PORT=3000
API_PORT=8080

# MongoDB — internal single-node replica set (change streams power GraphQL
# subscriptions). Override the connection string only to point at managed Mongo.
# Keep MONGO_DATABASE=fogos in prod (the demo DB is fogos_demo).
MONGO_CONNECTION_STRING=mongodb://mongo:27017/?replicaSet=rs0
MONGO_DATABASE=fogos

# Redis — queue, distributed locks, subscription bridge, rate limiter.
# Override only to point at managed Redis.
REDIS_CONNECTION_STRING=redis:6379

# Web → API. Server-side calls stay on the internal network (no CORS, like dev).
FOGOS_API_URL=http://api:8080

# Object storage (MinIO in-stack; any S3/R2 when managed) — holds incident photos.
# STORAGE_ENDPOINT: S3 endpoint api/worker talk to. STORAGE_BUCKET is created and
# made public-read by minio-init. STORAGE_PUBLIC_BASE_URL is the public URL photos
# resolve from — point it at your CDN/host domain for external access.
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=incident-photos
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/incident-photos
# MinIO admin user doubles as the S3 access key; the password is the S3 secret key.
# CHANGE MINIO_ROOT_PASSWORD before exposing the stack.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# Auth — self-issued RS256 JWTs. Empty ⇒ an EPHEMERAL key is generated at boot with
# a loud warning (tokens die on restart, instances don't share keys — fine for a
# smoke test, NOT for prod). Set a stable RSA private key (a PEM string or a path to
# a PEM file) in prod. Issuer/audience default to fogos.pt / fogos-api in
# appsettings.json; override via Auth__Issuer / Auth__Audience if needed.
AUTH_RSA_PRIVATE_KEY_PEM=

# ═══ 2. OPTIONAL — external data sources ═════════════════════════════════════
# Empty key = that source is simply off; everything else runs normally.

# NASA FIRMS active-fire key — powers satellite hotspots + the spread timeline.
# Free key at https://firms.modaps.eosdis.nasa.gov/api/ (empty ⇒ FIRMS ingest off).
NASA_FIRMS_KEY=

# Flightradar24 API key — aircraft tracking + firefighting-plane↔incident association.
# Commercial (fr24api.flightradar24.com). Empty ⇒ FR24 polling off. A free adsb.fi
# feed is a possible alternative via Sources__AdsbFi__BaseUrl (client exists; not
# wired here yet). FR24_MONTHLY_BUDGET is the shared credit ceiling; 0 ⇒ guard off.
FR24_API_KEY=
FR24_MONTHLY_BUDGET=0

# ═══ 3. OPTIONAL — push notifications (FCM) ══════════════════════════════════
# Legacy push channel (an Expo swap is planned). Disabled-safe: with PUBLISH_FCM
# absent / Off / DryRun the FirebaseApp is never initialised, so NO credentials are
# needed to boot. Default DryRun captures would-be sends to DISCORD_DRYRUN_WEBHOOK
# (if set). Flip to On only after the switchover playbook, with the credentials set.
# Accepted values: Off | DryRun | On.
PUBLISH_FCM=DryRun
# Service account, only read when a real send happens (PUBLISH_FCM=On):
# FCM_CREDENTIALS_PATH = path to a service-account JSON mounted into the worker;
# FCM_PROJECT_ID = the Firebase project id.
FCM_CREDENTIALS_PATH=
FCM_PROJECT_ID=

# ═══ OPTIONAL — ops & error reporting (empty = silent no-op) ═════════════════
# Discord webhooks: general (feed freshness / parser drift / job notices), errors
# (error alerts), dry-run (captures what publishers WOULD have sent).
DISCORD_GENERAL_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=
DISCORD_DRYRUN_WEBHOOK=
# Sentry DSN for error reporting (empty ⇒ disabled).
SENTRY_DSN=
