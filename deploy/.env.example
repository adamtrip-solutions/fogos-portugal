# Copy to deploy/.env on the server and fill in the secrets. Unset keys fall back to the safe
# defaults baked into compose.yml (photo storage inert until R2 is set, all webhooks silent,
# FR24 in DryRun). NEVER commit the real .env — it is the primary disaster-recovery artifact
# (back it up offsite, see README).

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 1) CORE — the in-stack defaults work out of the box. Change passwords only if you expose ports.
# ─────────────────────────────────────────────────────────────────────────────────────────────
WEB_PORT=3000                                              # host port for web (127.0.0.1 only; tunnel maps to it)
API_PORT=8080                                              # host port for api (127.0.0.1 only; tunnel maps to it)
MONGO_CONNECTION_STRING=mongodb://mongo:27017/?replicaSet=rs0  # in-stack Mongo; point at managed Mongo to override
MONGO_DATABASE=fogos                                       # database name (demo seeder uses fogos_demo instead)
REDIS_CONNECTION_STRING=redis:6379                         # in-stack Redis; queue + idempotency + change-stream bridge
FOGOS_API_URL=http://api:8080                              # web → api on the internal network (no CORS, like dev)

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 2) STORAGE — Cloudflare R2 (external, managed). REQUIRED for photo upload/serve; the stack
#    boots without it (photo features stay inert). Create a bucket, then an R2 API token with
#    Object Read & Write, then enable public access (r2.dev subdomain or a custom domain).
# ─────────────────────────────────────────────────────────────────────────────────────────────
STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com  # R2 S3 endpoint (Cloudflare dashboard → R2 → account id)
STORAGE_ACCESS_KEY=                                        # R2 API token Access Key ID (Object Read & Write)
STORAGE_SECRET_KEY=                                        # R2 API token Secret Access Key
STORAGE_BUCKET=incident-photos                             # R2 bucket name
STORAGE_PUBLIC_BASE_URL=https://media.fogosportugal.pt     # public bucket URL: r2.dev subdomain or a custom domain

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 3) OPTIONAL — everything here boots fine when empty; set as you turn features on.
# ─────────────────────────────────────────────────────────────────────────────────────────────
AUTH_RSA_PRIVATE_KEY_PEM=          # RS256 JWT signing key; empty = ephemeral key (tokens die on restart). Set a stable PEM in prod.
DISCORD_GENERAL_WEBHOOK=           # ops info feed (Discord webhook URL); empty = silent
DISCORD_ERRORS_WEBHOOK=            # ops error feed (Discord webhook URL); empty = silent
DISCORD_DRYRUN_WEBHOOK=            # dry-run capture feed (Discord webhook URL); empty = silent
SENTRY_DSN=                        # error reporting DSN (sentry.io); empty = disabled
NASA_FIRMS_KEY=                    # NASA FIRMS map key (free: firms.modaps.eosdis.nasa.gov/api) for hotspots/spread timeline; empty = feature off
FR24_API_KEY=                      # Flightradar24 API key (commercial; aircraft tracking); empty = FR24 off
FR24_MONTHLY_BUDGET=0              # shared FR24 monthly credit budget; 0 = fail closed (refuses to spend)
FR24_MODE=DryRun                   # FR24 spend gate: Off | DryRun (runs poll gates, no paid call) | On (live, needs key+budget)
