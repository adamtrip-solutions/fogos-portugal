# Copy to deploy/.env on the server and fill in the secrets. Everything here is what the
# compose stack reads; unset keys fall back to the safe defaults baked into compose.yml
# (FCM push DryRun, all webhooks silent). NEVER commit the real .env — it is the
# primary disaster-recovery artifact (back it up offsite, see README).

# ── Host port bindings (127.0.0.1 only; the Cloudflare tunnel maps hostnames to these) ──
WEB_PORT=3000
API_PORT=8080

# ── Infrastructure (internal service names; override only to point at managed infra) ──
MONGO_CONNECTION_STRING=mongodb://mongo:27017/?replicaSet=rs0
MONGO_DATABASE=fogos
REDIS_CONNECTION_STRING=redis:6379

# ── Web → API (server-side, internal network; CORS stays irrelevant like in dev) ──
FOGOS_API_URL=http://api:8080

# ── Object storage (MinIO) ──
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=incident-photos
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/incident-photos
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# ── Auth (self-issued RS256 JWTs). Leave empty to auto-generate an ephemeral key (tokens ──
# ── die on restart, logged loudly). In prod set a stable PEM. ──
AUTH_RSA_PRIVATE_KEY_PEM=

# ── Ops (Discord webhooks). Empty = silent no-op. ──
DISCORD_GENERAL_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=
DISCORD_DRYRUN_WEBHOOK=

# ── Push (FCM). Off | DryRun | On. Keep DryRun until the switchover playbook. ──
PUBLISH_FCM=DryRun

# ── FCM (FirebaseAdmin). Path to a service-account JSON mounted into the worker, or empty. ──
FCM_CREDENTIALS_PATH=
FCM_PROJECT_ID=

# ── External sources (keys empty = source disabled; FR24 budget 0 = guard disabled). ──
NASA_FIRMS_KEY=
FR24_API_KEY=
FR24_MONTHLY_BUDGET=0

# ── Errors ──
SENTRY_DSN=
