# Deployed image tags, one per release train (see .github/workflows/release-please.yml).
#   API_VERSION → api + worker + renderer images (the `api` component: api-vX.Y.Z)
#   WEB_VERSION → web image                       (the `web` component: web-vX.Y.Z)
# The deploy workflow rewrites the matching line on each release; edit + re-deploy to roll back.
# `latest` is the pre-release bootstrap value; real deploys pin exact versions.
API_VERSION=latest
WEB_VERSION=latest
