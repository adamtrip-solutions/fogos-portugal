{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sentry": {
    "Dsn": ""
  },
  "Mongo": {
    "ConnectionString": "",
    "Database": "fogos",
    "FlightPositionTtlDays": 180
  },
  "Redis": {
    "ConnectionString": ""
  },
  "ObjectStorage": {
    "Endpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "incident-photos",
    "PublicBaseUrl": "",
    "Region": "auto",
    "ForcePathStyle": true
  },
  "Ops": {
    "DiscordGeneralWebhook": null,
    "DiscordErrorsWebhook": null,
    "DiscordDryRunWebhook": null
  },
  "Publishing": {
    "Channels": {
      "twitter": "DryRun",
      "telegram": "DryRun",
      "facebook": "DryRun",
      "fcm": "DryRun",
      "discordPosts": "DryRun"
    }
  },
  "Auth": {
    "Issuer": "fogos.pt",
    "Audience": "fogos-api",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "RsaPrivateKeyPem": ""
  },
  "RateLimit": {
    "WindowSeconds": 60,
    "Anonymous": { "Requests": 30, "CostBudget": 500, "Subscriptions": 0 },
    "Registered": { "Requests": 300, "CostBudget": 5000, "Subscriptions": 2 },
    "FirstParty": { "Requests": 1200, "CostBudget": 50000, "Subscriptions": 10 },
    "Operator": { "Requests": 600, "CostBudget": 20000, "Subscriptions": 4 }
  },
  "PhotoGate": {
    "PerIpPerMinute": 3,
    "PerIncidentPerIpPerHour": 8,
    "PerIncidentPerHour": 80,
    "PendingPerIncident": 50
  }
}
